# ==========================================
# CẤU HÌNH API M7AI VÀ MCP (CỦA AGENT)
# ==========================================
MCP_URL=http://127.0.0.1:5000/mcp
OPENAI_API_KEY=openai_api_key
OPENAI_BASE_URL=https://yh.m7ai.com/v1
OPENAI_TEXT_ENDPOINT=chat_completions
OPENAI_CHAT_COMPLETIONS_FALLBACK=1

MODEL_NAME=gpt-5.4-mini
PLANNER_MODEL=gpt-5.4
ARCHITECT_MODEL=gpt-5.4
RTL_MODEL=gpt-5.4
TB_MODEL=gpt-5.4
VCS_MODEL=gpt-5.4-mini
DEBUG_MODEL=gpt-5.4
REVIEW_MODEL=gpt-5.4-mini


# ==========================================
# CẤU HÌNH CHO HỆ THỐNG RAG ENGINE
# ==========================================
# Tên mô hình nhúng cục bộ (Miễn phí, chạy offline)
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Thư mục lưu trữ Vector DB
PERSIST_DIRECTORY=./chroma_db_local
# Thư mục chứa tài liệu spec kiến trúc
KNOWLEDGE_BASE_PATH=./knowledge_base
# Thư mục chứa code RTL cũ
OUTPUT_RTL_PATH=./output_rtl
